---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProseSection from '../../components/ProseSection.astro';
import NewsCard from '../../components/NewsCard.astro';
import CTASection from '../../components/CTASection.astro';
import NewsGraphic from '../../components/graphics/headers/NewsGraphic.astro';
import { newsSection, getSortedNews } from '../../content/news';
import { home, pageMeta } from '../../content/site';

const articles = getSortedNews();
---

<Layout title={pageMeta.news.title} description={pageMeta.news.description} path="/news">
  <PageHeader
    label="News"
    title={newsSection.title}
    description={newsSection.description}
    path="/news"
    tags={['Architektur', 'Enterprise-KI', 'Legacy']}
  >
    <NewsGraphic slot="graphic" />
  </PageHeader>
  <ProseSection title={newsSection.intro.title} paragraphs={newsSection.intro.paragraphs} />
  <section class="blueprint-grid-light section-split py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      {
        articles.length > 0 ? (
          <div class="space-y-8">
            {articles.map((article, index) => (
              <NewsCard {...article} featured={index === 0} />
            ))}
          </div>
        ) : (
          <div class="card max-w-2xl p-8">
            <p class="font-mono text-[0.65rem] text-accent-deep/60">news/ · leer</p>
            <h2 class="mt-3 text-lg font-semibold text-text">Noch keine Beiträge</h2>
            <p class="mt-3 leading-relaxed text-text-muted">
              Hier erscheinen in Kürze Einordnungen zu Architektur, KI und Legacy-Modernisierung.
            </p>
          </div>
        )
      }
    </div>
  </section>
  <CTASection
    title="Thema trifft Ihre Ausgangslage?"
    description="News-Beiträge sind Einordnungen — im Erstgespräch klären wir, was für Ihr System konkret relevant ist."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
