---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ExpertDetail from '../components/ExpertDetail.astro';
import CTASection from '../components/CTASection.astro';
import ExpertGraphic from '../components/graphics/headers/ExpertGraphic.astro';
import IndustryStrip from '../components/IndustryStrip.astro';
import { expert, home, pageMeta, siteConfig } from '../content/site';
---

<Layout title={pageMeta.expert.title} description={pageMeta.expert.description} path="/expertenprofil">
  <PageHeader
    label="Expertenprofil"
    title={siteConfig.ownerName}
    description={expert.description}
    path="/expertenprofil"
    tags={['iSAQB CPSA-A', 'CSM', '30+ Jahre']}
  >
    <ExpertGraphic slot="graphic" />
  </PageHeader>
  <IndustryStrip compact />
  <section class="blueprint-grid-light relative border-b border-border py-16 sm:py-20">
    <div class="blueprint-accent-bar absolute top-0 left-0 right-0" aria-hidden="true"></div>
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="card card-interactive relative max-w-3xl overflow-hidden p-8">
        <p class="font-mono text-[0.65rem] text-accent-deep/60">context/profile.md</p>
        <p class="mt-3 text-sm font-medium text-text">{siteConfig.ownerName}</p>
        <h2 class="mt-1 text-xl font-semibold text-text">{expert.headline}</h2>
        {expert.subtitle && (
          <p class="mt-2 text-sm leading-relaxed text-text-muted">{expert.subtitle}</p>
        )}
        <p class="mt-4 font-mono text-sm text-accent-deep">{expert.certification}</p>
        {expert.languages && (
          <p class="mt-2 font-mono text-xs text-text-muted">
            {expert.languages.join(' · ')}
          </p>
        )}
        <ul class="mt-8 space-y-4">
          {
            expert.points.map((point) => (
              <li class="flex gap-3 text-sm leading-relaxed text-text-muted">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                {point}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
  <ExpertDetail
    title={expert.detail.title}
    paragraphs={expert.detail.paragraphs}
    competencies={expert.detail.competencies}
    domains={expert.detail.domains}
  />
  <CTASection
    title="Architekturkompetenz für Ihre Modernisierung."
    description="KI-gestützte Analyse und iSAQB-zertifizierte Methodik — von der Ist-Aufnahme bis zur Zielarchitektur."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
