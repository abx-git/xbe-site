---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProseSection from '../components/ProseSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import CTASection from '../components/CTASection.astro';
import ProcessGraphic from '../components/graphics/headers/ProcessGraphic.astro';
import { process, home, pageMeta } from '../content/site';
---

<Layout title={pageMeta.process.title} description={pageMeta.process.description} path="/vorgehensweise">
  <PageHeader
    label="Vorgehensweise"
    title={process.title}
    description={process.description}
    path="/vorgehensweise"
    tags={['5 Phasen', 'WRK', 'Liefergegenstände']}
  >
    <ProcessGraphic slot="graphic" />
  </PageHeader>
  <ProseSection title={process.intro.title} paragraphs={process.intro.paragraphs} />
  <section class="blueprint-grid-light section-split py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeader label="Phasenmodell" title="Fünf Schritte — vom Assessment zur Umsetzung" />
      <ProcessSteps steps={process.steps} />
    </div>
  </section>
  <CTASection
    title="Strukturiert vom Assessment zur KI-gestützten Umsetzung."
    description="Jede Phase liefert eigenständige Ergebnisse — Analyse und Dokumentation auch als abgeschlossenes Beratungsprojekt."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
