---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProseSection from '../components/ProseSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ServiceBlock from '../components/ServiceBlock.astro';
import CTASection from '../components/CTASection.astro';
import LeistungenGraphic from '../components/graphics/headers/LeistungenGraphic.astro';
import C4ContextDiagram from '../components/diagrams/C4ContextDiagram.astro';
import DependencyGraph from '../components/diagrams/DependencyGraph.astro';
import MigrationPath from '../components/diagrams/MigrationPath.astro';
import IterativeMigrationCycle from '../components/diagrams/IterativeMigrationCycle.astro';
import { services, home, pageMeta } from '../content/site';

const diagramMap = {
  analyse: C4ContextDiagram,
  dokumentation: DependencyGraph,
  migrationsplanung: MigrationPath,
  'ki-migration': IterativeMigrationCycle,
} as const;
---

<Layout title={pageMeta.services.title} description={pageMeta.services.description} path="/leistungen">
  <PageHeader
    label="Leistungsprofil"
    title={services.title}
    description={services.description}
    path="/leistungen"
    tags={['4 Bausteine', 'arc42', 'C4']}
  >
    <LeistungenGraphic slot="graphic" />
  </PageHeader>
  <ProseSection title={services.intro.title} paragraphs={services.intro.paragraphs} />
  <section class="blueprint-grid-light section-split py-20 sm:py-28">
    <div class="mx-auto max-w-6xl space-y-28 px-4 sm:px-6">
      <SectionHeader label="Bausteine" title="Vier aufeinander aufbauende Leistungen" />
      {
        services.items.map((item, index) => {
          const Diagram = diagramMap[item.id];
          return (
            <ServiceBlock
              title={item.title}
              description={item.description}
              standards={item.standards}
              details={item.details}
              deliverables={item.deliverables}
              index={index + 1}
              reversed={index % 2 === 1}
            >
              <Diagram />
            </ServiceBlock>
          );
        })
      }
    </div>
  </section>
  <CTASection
    title="Von der Analyse bis zur iterativen Umsetzung."
    description="Leistungsbausteine einzeln oder kombiniert — jeweils mit definierten Liefergegenständen und validierten Ergebnissen."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
