---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProseSection from '../components/ProseSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SecurityGrid from '../components/SecurityGrid.astro';
import ConfidentialitySection from '../components/ConfidentialitySection.astro';
import TagCloud from '../components/TagCloud.astro';
import CTASection from '../components/CTASection.astro';
import MethodikGraphic from '../components/graphics/headers/MethodikGraphic.astro';
import KnowledgeCatalogSection from '../components/KnowledgeCatalogSection.astro';
import PrototypingProofs from '../components/PrototypingProofs.astro';
import { methodology, home, pageMeta } from '../content/site';

const dual = methodology.dualMethods;
const tools = methodology.tools;
const prototyping = methodology.prototyping;
---

<Layout title={pageMeta.methodology.title} description={pageMeta.methodology.description} path="/methodik">
  <PageHeader
    label="Methodik & Sicherheit"
    title={methodology.title}
    description={methodology.description}
    path="/methodik"
    tags={['Hintergrund', 'Standards', 'Enterprise-KI']}
  >
    <MethodikGraphic slot="graphic" />
  </PageHeader>
  <ProseSection title={methodology.intro.title} paragraphs={methodology.intro.paragraphs} />

  <section class="section-dark relative py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="eyebrow text-center text-accent-hover">{dual.eyebrow}</p>
      <h2 class="display-md mt-3 text-center text-text-on-dark">{dual.title}</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center leading-relaxed text-text-muted-on-dark">
        {dual.description}
      </p>
      <div class="mt-10 grid gap-4 lg:grid-cols-2">
        {
          dual.pillars.map((pillar) => (
            <div class="rounded-xl border border-white/10 bg-white/5 p-7">
              <p class="font-mono text-[0.65rem] uppercase tracking-widest text-accent-hover">
                {pillar.id === 'agm' ? 'Architecture Context' : 'Domain Context'}
              </p>
              <h3 class="mt-2 text-lg font-semibold text-text-on-dark">{pillar.title}</h3>
              <p class="mt-3 text-sm italic leading-relaxed text-text-muted-on-dark">„{pillar.thesis}"</p>
              <dl class="mt-5 space-y-2 font-mono text-xs text-text-muted-on-dark">
                <div>
                  <dt class="text-accent-hover">Frage</dt>
                  <dd class="mt-0.5 text-text-on-dark/90">{pillar.focus}</dd>
                </div>
                <div>
                  <dt class="text-accent-hover">Artefakt</dt>
                  <dd class="mt-0.5 text-text-on-dark/90">{pillar.artifact}</dd>
                </div>
                <div>
                  <dt class="text-accent-hover">Rolle für KI</dt>
                  <dd class="mt-0.5 text-text-on-dark/90">{pillar.role}</dd>
                </div>
              </dl>
            </div>
          ))
        }
      </div>
      <p class="mx-auto mt-8 max-w-3xl text-center text-sm leading-relaxed text-text-muted-on-dark">
        {dual.bridge}
      </p>
    </div>
  </section>

  <section class="blueprint-grid-light relative py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeader label="Säulen" title="Qualität durch Prozess und Standards" />
      <SecurityGrid items={methodology.items} />
    </div>
  </section>
  <ConfidentialitySection
    title={methodology.confidentiality.title}
    description={methodology.confidentiality.description}
    briefing={methodology.confidentiality.briefing}
    contractual={methodology.confidentiality.contractual}
    technical={methodology.confidentiality.technical}
    obligations={methodology.confidentiality.obligations}
    legalNote={methodology.confidentiality.legalNote}
  />
  <TagCloud title="Referenz-Frameworks & Standards" items={methodology.frameworks} />
  <KnowledgeCatalogSection
    title={methodology.knowledgeCatalog.title}
    description={methodology.knowledgeCatalog.description}
    alignment={methodology.knowledgeCatalog.alignment}
    scope={methodology.knowledgeCatalog.scope}
    links={methodology.knowledgeCatalog.links}
  />
  <section class="section-dark relative py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="eyebrow text-center text-accent-hover">{tools.eyebrow}</p>
      <h2 class="display-md mt-3 text-center text-text-on-dark">{tools.title}</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center leading-relaxed text-text-muted-on-dark">
        {tools.description}
      </p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        <a
          href="/methodik/agm"
          class="group rounded-xl border border-white/10 bg-white/5 p-7 no-underline transition-colors hover:border-accent/40 hover:bg-white/8"
        >
          <p class="font-mono text-[0.65rem] uppercase tracking-widest text-accent-hover">Interaktiv · AGM</p>
          <h3 class="mt-2 text-lg font-semibold text-text-on-dark">AGM Assistant</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted-on-dark">
            Install → Adopt → Continue → Evolve → Verify. Session-Prompts kopieren oder MCP in der IDE.
          </p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs text-accent-hover transition-transform group-hover:translate-x-0.5">
            Assistent öffnen
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
        <a
          href="/methodik/agm-poster"
          class="group rounded-xl border border-white/10 bg-white/5 p-7 no-underline transition-colors hover:border-accent/40 hover:bg-white/8"
        >
          <p class="font-mono text-[0.65rem] uppercase tracking-widest text-accent-hover">Referenz · AGM</p>
          <h3 class="mt-2 text-lg font-semibold text-text-on-dark">One-Page-Poster</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted-on-dark">
            Golden Path, Tracks, OKF, Prinzipien und Workflows — druckbar als kompakte Karte.
          </p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs text-accent-hover transition-transform group-hover:translate-x-0.5">
            Poster öffnen
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
        <a
          href="/methodik/e2"
          class="group rounded-xl border border-white/10 bg-white/5 p-7 no-underline transition-colors hover:border-accent/40 hover:bg-white/8"
        >
          <p class="font-mono text-[0.65rem] uppercase tracking-widest text-accent-hover">Interaktiv · E2</p>
          <h3 class="mt-2 text-lg font-semibold text-text-on-dark">E2 Board</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted-on-dark">
            Event Storming, DDD, BDD, USM, Event Modeling — Export als schema-konformes .storm.json.
          </p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs text-accent-hover transition-transform group-hover:translate-x-0.5">
            Board öffnen
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
        <a
          href="/methodik/e2-poster"
          class="group rounded-xl border border-white/10 bg-white/5 p-7 no-underline transition-colors hover:border-accent/40 hover:bg-white/8"
        >
          <p class="font-mono text-[0.65rem] uppercase tracking-widest text-accent-hover">Referenz · E2</p>
          <h3 class="mt-2 text-lg font-semibold text-text-on-dark">One-Page-Poster</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted-on-dark">
            Workshop → Export → KI-Nutzung → Brücke zu AGM — druckbar als kompakte Karte.
          </p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs text-accent-hover transition-transform group-hover:translate-x-0.5">
            Poster öffnen
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>
  <PrototypingProofs
    eyebrow={prototyping.eyebrow}
    title={prototyping.title}
    description={prototyping.description}
    items={prototyping.items}
    variant="light"
  />
  <CTASection
    title="Leistungen im Vordergrund — Methodik schafft Vertrauen."
    description="Etablierte Architekturstandards, Enterprise-KI-Infrastruktur und verbindliche Validierung hinter der Beratungsleistung."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
