---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProseSection from '../components/ProseSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SecurityGrid from '../components/SecurityGrid.astro';
import ConfidentialitySection from '../components/ConfidentialitySection.astro';
import TagCloud from '../components/TagCloud.astro';
import CTASection from '../components/CTASection.astro';
import MethodikGraphic from '../components/graphics/headers/MethodikGraphic.astro';
import KnowledgeCatalogSection from '../components/KnowledgeCatalogSection.astro';
import { methodology, home, pageMeta } from '../content/site';
---

<Layout title={pageMeta.methodology.title} description={pageMeta.methodology.description} path="/methodik">
  <PageHeader
    label="Methodik & Sicherheit"
    title={methodology.title}
    description={methodology.description}
    path="/methodik"
    tags={['Enterprise API', 'OKF · MCP', 'iSAQB']}
  >
    <MethodikGraphic slot="graphic" />
  </PageHeader>
  <ProseSection title={methodology.intro.title} paragraphs={methodology.intro.paragraphs} />
  <section class="blueprint-grid-light relative py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeader label="Säulen" title="Qualität durch Prozess und Standards" />
      <SecurityGrid items={methodology.items} />
    </div>
  </section>
  <ConfidentialitySection
    title={methodology.confidentiality.title}
    description={methodology.confidentiality.description}
    briefing={methodology.confidentiality.briefing}
    contractual={methodology.confidentiality.contractual}
    technical={methodology.confidentiality.technical}
    obligations={methodology.confidentiality.obligations}
    legalNote={methodology.confidentiality.legalNote}
  />
  <TagCloud title="Referenz-Frameworks & Standards" items={methodology.frameworks} />
  <KnowledgeCatalogSection
    title={methodology.knowledgeCatalog.title}
    description={methodology.knowledgeCatalog.description}
    alignment={methodology.knowledgeCatalog.alignment}
    scope={methodology.knowledgeCatalog.scope}
    links={methodology.knowledgeCatalog.links}
  />
  <section class="section-dark relative py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <p class="eyebrow text-center text-accent-hover">AGM · Architecture Graph</p>
      <h2 class="display-md mt-3 text-center text-text-on-dark">Werkzeuge zur Methode</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center leading-relaxed text-text-muted-on-dark">
        Assistant für den Golden Path (Prompts &amp; MCP) und ein One-Page-Poster als kompakte Referenz.
      </p>
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        <a
          href="/methodik/agm"
          class="group rounded-xl border border-white/10 bg-white/5 p-7 no-underline transition-colors hover:border-accent/40 hover:bg-white/8"
        >
          <p class="font-mono text-[0.65rem] uppercase tracking-widest text-accent-hover">Interaktiv</p>
          <h3 class="mt-2 text-lg font-semibold text-text-on-dark">AGM Assistant</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted-on-dark">
            Install → Adopt → Continue → Evolve → Verify. Session-Prompts kopieren oder MCP in der IDE.
          </p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs text-accent-hover transition-transform group-hover:translate-x-0.5">
            Assistent öffnen
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
        <a
          href="/methodik/agm-poster"
          class="group rounded-xl border border-white/10 bg-white/5 p-7 no-underline transition-colors hover:border-accent/40 hover:bg-white/8"
        >
          <p class="font-mono text-[0.65rem] uppercase tracking-widest text-accent-hover">Referenz</p>
          <h3 class="mt-2 text-lg font-semibold text-text-on-dark">One-Page-Poster</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-muted-on-dark">
            Golden Path, Tracks, OKF, Prinzipien und Workflows — druckbar als kompakte Karte.
          </p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs text-accent-hover transition-transform group-hover:translate-x-0.5">
            Poster öffnen
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>
  <CTASection
    title="Methodik schafft Vertrauen in die Ergebnisse."
    description="Etablierte Architekturstandards, Enterprise-KI-Infrastruktur und verbindliche Validierung."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
