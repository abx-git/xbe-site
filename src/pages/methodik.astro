---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ProseSection from '../components/ProseSection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SecurityGrid from '../components/SecurityGrid.astro';
import ConfidentialitySection from '../components/ConfidentialitySection.astro';
import TagCloud from '../components/TagCloud.astro';
import CTASection from '../components/CTASection.astro';
import MethodikGraphic from '../components/graphics/headers/MethodikGraphic.astro';
import KnowledgeCatalogSection from '../components/KnowledgeCatalogSection.astro';
import { methodology, home, pageMeta } from '../content/site';
---

<Layout title={pageMeta.methodology.title} description={pageMeta.methodology.description} path="/methodik">
  <PageHeader
    label="Methodik & Sicherheit"
    title={methodology.title}
    description={methodology.description}
    path="/methodik"
    tags={['Enterprise API', 'OKF · MCP', 'iSAQB']}
  >
    <MethodikGraphic slot="graphic" />
  </PageHeader>
  <ProseSection title={methodology.intro.title} paragraphs={methodology.intro.paragraphs} />
  <section class="blueprint-grid-light relative py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <SectionHeader label="Säulen" title="Qualität durch Prozess und Standards" />
      <SecurityGrid items={methodology.items} />
    </div>
  </section>
  <ConfidentialitySection
    title={methodology.confidentiality.title}
    description={methodology.confidentiality.description}
    briefing={methodology.confidentiality.briefing}
    contractual={methodology.confidentiality.contractual}
    technical={methodology.confidentiality.technical}
    obligations={methodology.confidentiality.obligations}
    legalNote={methodology.confidentiality.legalNote}
  />
  <TagCloud title="Referenz-Frameworks & Standards" items={methodology.frameworks} />
  <KnowledgeCatalogSection
    title={methodology.knowledgeCatalog.title}
    description={methodology.knowledgeCatalog.description}
    alignment={methodology.knowledgeCatalog.alignment}
    scope={methodology.knowledgeCatalog.scope}
    links={methodology.knowledgeCatalog.links}
  />
  <CTASection
    title="Methodik schafft Vertrauen in die Ergebnisse."
    description="Etablierte Architekturstandards, Enterprise-KI-Infrastruktur und verbindliche Validierung."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
