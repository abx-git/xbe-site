---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import ProseSection from '../components/ProseSection.astro';
import ContextGrid from '../components/ContextGrid.astro';
import ValueCards from '../components/ValueCards.astro';
import NewsPreview from '../components/NewsPreview.astro';
import IndustryStrip from '../components/IndustryStrip.astro';
import PrototypingProofs from '../components/PrototypingProofs.astro';
import TeaserGrid from '../components/TeaserGrid.astro';
import CTASection from '../components/CTASection.astro';
import { home, pageMeta } from '../content/site';
---

<Layout title={pageMeta.home.title} description={pageMeta.home.description}>
  <Hero
    title={home.title}
    description={home.description}
    cta={{ label: home.cta, href: '/kontakt' }}
  />
  <IndustryStrip />
  <ProseSection title={home.intro.title} paragraphs={home.intro.paragraphs} />
  <ContextGrid title={home.context.title} items={home.context.items} />
  <ValueCards values={home.values} />
  <PrototypingProofs
    eyebrow={home.prototyping.eyebrow}
    title={home.prototyping.title}
    description={home.prototyping.description}
    items={home.prototyping.items}
  />
  <NewsPreview />
  <TeaserGrid teasers={home.teasers} />
  <CTASection
    title="Architekturberatung und KI-gestützte Umsetzung."
    description="Im Erstgespräch klären wir Ausgangssituation, Scope und passende Leistungsbausteine — von der Ist-Analyse bis zur iterativen Softwareentwicklung."
    ctaLabel={home.cta}
    ctaHref="/kontakt"
  />
</Layout>
