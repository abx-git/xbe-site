---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import AgmAssistantEmbed from '../../components/AgmAssistantEmbed.astro';
import AgmAssistantGraphic from '../../components/graphics/headers/AgmAssistantGraphic.astro';
import { methodology, pageMeta } from '../../content/site';

const a = methodology.assistant;
---

<Layout title={pageMeta.agmAssistant.title} description={pageMeta.agmAssistant.description} path="/methodik/agm">
  <PageHeader
    label="Methodik · AGM"
    title={a.title}
    description={a.description}
    tags={['Golden Path', 'Prompts', 'MCP']}
  >
    <AgmAssistantGraphic slot="graphic" />
  </PageHeader>

  <section class="blueprint-grid-light py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <ol class="mb-10 grid gap-3 sm:grid-cols-5">
        {
          a.steps.map((step) => (
            <li class="rounded-lg border border-border bg-bg-elevated px-3 py-4 text-center">
              <span class="font-mono text-lg font-medium text-accent-deep">{step.n}</span>
              <p class="mt-1 text-sm font-medium text-text">{step.label}</p>
              <p class="mt-1 font-mono text-[0.6rem] text-text-muted">{step.hint}</p>
            </li>
          ))
        }
      </ol>
      <AgmAssistantEmbed />
    </div>
  </section>
</Layout>
