---

<div class="overflow-x-auto card p-4">
  <svg viewBox="0 0 320 280" class="mx-auto w-full max-w-sm" role="img" aria-label="Iterativer Migrationszyklus: Modul wählen, KI-Migration, Review, Test">
    <title>Iterative Migration Cycle</title>
    <circle cx="160" cy="130" r="90" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="6 4"/>

    <circle cx="160" cy="130" r="28" fill="#ffffff" stroke="#0c4a6e" stroke-width="1.5"/>
    <text x="160" y="126" text-anchor="middle" fill="#0c4a6e" font-size="8" font-weight="600" font-family="ui-monospace, monospace">Iterativ</text>
    <text x="160" y="138" text-anchor="middle" fill="#475569" font-size="7" font-family="ui-monospace, monospace">pro Modul</text>

    <rect x="115" y="20" width="90" height="36" rx="4" fill="#ffffff" stroke="#94a3b8" stroke-width="1.5"/>
    <text x="160" y="38" text-anchor="middle" fill="#1e293b" font-size="9" font-family="ui-monospace, monospace">Modul wählen</text>
    <text x="160" y="50" text-anchor="middle" fill="#475569" font-size="7" font-family="ui-monospace, monospace">Priorisierung</text>

    <rect x="230" y="112" width="80" height="36" rx="4" fill="#ffffff" stroke="#0c4a6e" stroke-width="1.5"/>
    <text x="270" y="130" text-anchor="middle" fill="#0c4a6e" font-size="9" font-family="ui-monospace, monospace">KI-Migration</text>
    <text x="270" y="142" text-anchor="middle" fill="#475569" font-size="7" font-family="ui-monospace, monospace">Transform</text>

    <rect x="115" y="210" width="90" height="36" rx="4" fill="#ffffff" stroke="#94a3b8" stroke-width="1.5"/>
    <text x="160" y="228" text-anchor="middle" fill="#1e293b" font-size="9" font-family="ui-monospace, monospace">Review</text>
    <text x="160" y="240" text-anchor="middle" fill="#475569" font-size="7" font-family="ui-monospace, monospace">iSAQB-Check</text>

    <rect x="10" y="112" width="70" height="36" rx="4" fill="#ffffff" stroke="#047857" stroke-width="1.5"/>
    <text x="45" y="130" text-anchor="middle" fill="#047857" font-size="9" font-family="ui-monospace, monospace">Test</text>
    <text x="45" y="142" text-anchor="middle" fill="#475569" font-size="7" font-family="ui-monospace, monospace">Validierung</text>

    <path d="M160 56 L160 102" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#iter-arrow)"/>
    <path d="M205 130 L228 130" stroke="#0c4a6e" stroke-width="1.5" marker-end="url(#iter-arrow-accent)"/>
    <path d="M160 204 L160 158" stroke="#94a3b8" stroke-width="1.5" marker-end="url(#iter-arrow)"/>
    <path d="M115 130 L82 130" stroke="#047857" stroke-width="1.5" marker-end="url(#iter-arrow-green)"/>
    <path d="M45 112 Q45 60 115 38" fill="none" stroke="#94a3b8" stroke-width="1" stroke-dasharray="4 3" marker-end="url(#iter-arrow)"/>

    <defs>
      <marker id="iter-arrow" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="#94a3b8"/>
      </marker>
      <marker id="iter-arrow-accent" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="#0c4a6e"/>
      </marker>
      <marker id="iter-arrow-green" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
        <path d="M0,0 L0,6 L8,3 z" fill="#047857"/>
      </marker>
    </defs>
  </svg>
  <p class="mt-3 text-center font-mono text-xs text-text-muted">Iterativer Migrationszyklus — pro Modul</p>
</div>
