---
interface Props {
  title: string;
  items: readonly string[];
}

const { title, items } = Astro.props;
---

<section class="blueprint-grid-light border-t border-border py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="section-label !mb-4">
      <span>Standards</span>
    </div>
    <p class="display-md text-text">{title}</p>
    <div class="mt-8 flex flex-wrap gap-2">
      {
        items.map((item) => (
          <span class="rounded-full border border-accent/20 bg-bg-elevated px-3.5 py-1.5 font-mono text-xs text-accent-deep transition-colors hover:border-accent/50 hover:bg-accent-subtle/50">
            {item}
          </span>
        ))
      }
    </div>
  </div>
</section>
