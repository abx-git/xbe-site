---
import PageGraphic from '../PageGraphic.astro';
---

<PageGraphic caption="vorgehensweise · 5 phasen">
  <svg viewBox="0 0 480 360" class="w-full" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Fünfstufiges Phasenmodell vom Assessment zur Migration">
    <defs>
      <pattern id="pg-grid" width="24" height="24" patternUnits="userSpaceOnUse">
        <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(56,189,248,0.1)" stroke-width="0.5"/>
      </pattern>
      <linearGradient id="pg-line" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#38bdf8"/>
        <stop offset="100%" stop-color="rgba(56,189,248,0.1)"/>
      </linearGradient>
    </defs>
    <rect width="480" height="360" fill="url(#pg-grid)"/>

    <!-- Vertical timeline -->
    <line x1="120" y1="40" x2="120" y2="320" stroke="url(#pg-line)" stroke-width="2"/>

    <!-- Phase nodes -->
    <circle cx="120" cy="60" r="18" fill="#0c1220" stroke="#38bdf8" stroke-width="2"/>
    <text x="120" y="64" text-anchor="middle" fill="#38bdf8" font-size="10" font-weight="600" font-family="IBM Plex Mono, monospace">1</text>
    <rect x="160" y="42" width="280" height="36" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.4)" stroke-width="1"/>
    <text x="175" y="58" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">Assessment &amp; Scoping</text>
    <text x="175" y="70" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">blueprint.md#phase-1</text>

    <circle cx="120" cy="120" r="18" fill="#0c1220" stroke="#38bdf8" stroke-width="2"/>
    <text x="120" y="124" text-anchor="middle" fill="#38bdf8" font-size="10" font-weight="600" font-family="IBM Plex Mono, monospace">2</text>
    <rect x="160" y="102" width="280" height="36" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.4)" stroke-width="1"/>
    <text x="175" y="118" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">Ist-Analyse &amp; Architektur</text>
    <text x="175" y="130" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">arc42/ · C4 Context</text>

    <circle cx="120" cy="180" r="18" fill="#0c1220" stroke="#38bdf8" stroke-width="2"/>
    <text x="120" y="184" text-anchor="middle" fill="#38bdf8" font-size="10" font-weight="600" font-family="IBM Plex Mono, monospace">3</text>
    <rect x="160" y="162" width="280" height="36" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.4)" stroke-width="1"/>
    <text x="175" y="178" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">Dokumentation &amp; Bewertung</text>
    <text x="175" y="190" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">work/WRK-001</text>

    <circle cx="120" cy="240" r="18" fill="#0c1220" stroke="#38bdf8" stroke-width="2"/>
    <text x="120" y="244" text-anchor="middle" fill="#38bdf8" font-size="10" font-weight="600" font-family="IBM Plex Mono, monospace">4</text>
    <rect x="160" y="222" width="280" height="36" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.4)" stroke-width="1"/>
    <text x="175" y="238" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">Migrationsplanung</text>
    <text x="175" y="250" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Zielarchitektur · Roadmap</text>

    <circle cx="120" cy="300" r="20" fill="rgba(14,165,233,0.15)" stroke="#38bdf8" stroke-width="2.5"/>
    <text x="120" y="305" text-anchor="middle" fill="#f1f5f9" font-size="10" font-weight="600" font-family="IBM Plex Mono, monospace">5</text>
    <rect x="160" y="282" width="280" height="36" rx="4" fill="rgba(14,165,233,0.1)" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="175" y="298" fill="#f1f5f9" font-size="10" font-weight="500" font-family="IBM Plex Mono, monospace">Iterative KI-Migration</text>
    <text x="175" y="310" fill="#94a3b8" font-size="7" font-family="IBM Plex Mono, monospace">work/WRK-00N · Zyklen</text>

    <!-- Deliverable dots -->
    <circle cx="460" cy="60" r="3" fill="rgba(56,189,248,0.5)"/>
    <circle cx="460" cy="120" r="3" fill="rgba(56,189,248,0.5)"/>
    <circle cx="460" cy="180" r="3" fill="rgba(56,189,248,0.5)"/>
    <circle cx="460" cy="240" r="3" fill="rgba(56,189,248,0.5)"/>
    <circle cx="460" cy="300" r="4" fill="#f59e0b"/>
    <text x="380" y="340" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Liefergegenstände pro Phase</text>
  </svg>
</PageGraphic>
