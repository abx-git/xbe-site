---
import PageGraphic from '../PageGraphic.astro';
---

<PageGraphic caption="news · architektur & ki">
  <svg viewBox="0 0 480 360" class="w-full" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="News-Feed zu Architektur und KI">
    <defs>
      <pattern id="ng-grid" width="24" height="24" patternUnits="userSpaceOnUse">
        <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(56,189,248,0.1)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="480" height="360" fill="url(#ng-grid)"/>

    <line x1="80" y1="50" x2="80" y2="310" stroke="rgba(56,189,248,0.25)" stroke-width="1.5"/>
    <circle cx="80" cy="70" r="6" fill="#38bdf8"/>
    <circle cx="80" cy="150" r="6" fill="rgba(56,189,248,0.5)"/>
    <circle cx="80" cy="230" r="6" fill="rgba(56,189,248,0.35)"/>
    <circle cx="80" cy="290" r="5" fill="rgba(148,163,184,0.4)"/>

    <rect x="110" y="48" width="330" height="52" rx="4" fill="rgba(14,165,233,0.1)" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="130" y="68" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">2026-03-14 · AGM</text>
    <text x="130" y="84" fill="#f1f5f9" font-size="10" font-weight="500" font-family="IBM Plex Mono, monospace">Architekturwissen als Graph</text>

    <rect x="110" y="128" width="300" height="44" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.4)" stroke-width="1"/>
    <text x="130" y="148" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Enterprise-KI · Security</text>
    <text x="130" y="162" fill="#94a3b8" font-size="9" font-family="IBM Plex Mono, monospace">geplant · Einordnung</text>

    <rect x="110" y="208" width="280" height="44" rx="4" fill="rgba(255,255,255,0.03)" stroke="rgba(148,163,184,0.25)" stroke-width="1" stroke-dasharray="4 3"/>
    <text x="130" y="228" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Legacy · Migration</text>
    <text x="130" y="242" fill="#64748b" font-size="8" font-family="IBM Plex Mono, monospace">nächster Beitrag</text>

    <text x="110" y="320" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">kuratiert · ohne hype · sachlich</text>
  </svg>
</PageGraphic>
