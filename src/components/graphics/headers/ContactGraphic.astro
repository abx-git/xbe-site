---
import PageGraphic from '../PageGraphic.astro';
---

<PageGraphic caption="kontakt · direkter kanal">
  <svg viewBox="0 0 480 360" class="w-full" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Kontaktwege per E-Mail und LinkedIn">
    <defs>
      <pattern id="cg-grid" width="24" height="24" patternUnits="userSpaceOnUse">
        <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(56,189,248,0.1)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="480" height="360" fill="url(#cg-grid)"/>

    <!-- You node -->
    <rect x="60" y="140" width="120" height="60" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="120" y="165" text-anchor="middle" fill="#64748b" font-size="8" font-family="IBM Plex Mono, monospace">Sie</text>
    <text x="120" y="182" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">CTO / Tech Lead</text>

    <!-- Connection hub -->
    <circle cx="240" cy="170" r="28" fill="rgba(14,165,233,0.12)" stroke="#38bdf8" stroke-width="2"/>
    <text x="240" y="166" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">Erst-</text>
    <text x="240" y="180" text-anchor="middle" fill="#f1f5f9" font-size="9" font-weight="500" font-family="IBM Plex Mono, monospace">gespräch</text>

    <!-- Us node -->
    <rect x="300" y="140" width="120" height="60" rx="4" fill="rgba(14,165,233,0.1)" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="360" y="165" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">Beratung</text>
    <text x="360" y="182" text-anchor="middle" fill="#f1f5f9" font-size="10" font-family="IBM Plex Mono, monospace">Legacy · KI</text>

    <line x1="180" y1="170" x2="212" y2="170" stroke="rgba(56,189,248,0.5)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <line x1="268" y1="170" x2="300" y2="170" stroke="rgba(56,189,248,0.5)" stroke-width="1.5" stroke-dasharray="4 3"/>

    <!-- Channels below -->
    <line x1="240" y1="198" x2="240" y2="240" stroke="rgba(56,189,248,0.3)" stroke-width="1"/>

    <rect x="100" y="250" width="130" height="50" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="165" y="272" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">@ E-Mail</text>
    <text x="165" y="288" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">mailto · NDA möglich</text>

    <rect x="250" y="250" width="130" height="50" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="315" y="272" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">LinkedIn</text>
    <text x="315" y="288" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Direktnachricht</text>

    <line x1="200" y1="240" x2="165" y2="250" stroke="rgba(56,189,248,0.3)" stroke-width="1" stroke-dasharray="3 2"/>
    <line x1="280" y1="240" x2="315" y2="250" stroke="rgba(56,189,248,0.3)" stroke-width="1" stroke-dasharray="3 2"/>

    <!-- Briefing hints -->
    <rect x="120" y="60" width="240" height="50" rx="4" fill="rgba(245,158,11,0.06)" stroke="rgba(245,158,11,0.3)" stroke-width="1"/>
    <text x="240" y="80" text-anchor="middle" fill="#f59e0b" font-size="8" font-family="IBM Plex Mono, monospace">HILFREICH BEIM ERSTKONTAKT</text>
    <text x="240" y="96" text-anchor="middle" fill="#94a3b8" font-size="7" font-family="IBM Plex Mono, monospace">Stack · Teamgröße · Modernisierungsziel</text>
  </svg>
</PageGraphic>
