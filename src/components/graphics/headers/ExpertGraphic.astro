---
import PageGraphic from '../PageGraphic.astro';
---

<PageGraphic caption="expertenprofil · kompetenzgraph">
  <svg viewBox="0 0 480 360" class="w-full" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Kompetenzfelder und Architektur-Domänen eines iSAQB-zertifizierten Experten">
    <defs>
      <pattern id="eg-grid" width="24" height="24" patternUnits="userSpaceOnUse">
        <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(56,189,248,0.1)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="480" height="360" fill="url(#eg-grid)"/>

    <!-- Central hub -->
    <circle cx="240" cy="175" r="36" fill="rgba(14,165,233,0.15)" stroke="#38bdf8" stroke-width="2"/>
    <text x="240" y="168" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">iSAQB</text>
    <text x="240" y="182" text-anchor="middle" fill="#f1f5f9" font-size="10" font-weight="600" font-family="IBM Plex Mono, monospace">CPSA-A</text>
    <text x="240" y="196" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Advanced</text>

    <!-- Satellite nodes -->
    <line x1="240" y1="139" x2="240" y2="70" stroke="rgba(56,189,248,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <rect x="175" y="40" width="130" height="44" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="240" y="60" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">Enterprise Architektur</text>
    <text x="240" y="74" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">arc42 · C4 · ADR</text>

    <line x1="276" y1="175" x2="360" y2="120" stroke="rgba(56,189,248,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <rect x="330" y="95" width="120" height="44" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="390" y="115" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">Legacy-Analyse</text>
    <text x="390" y="129" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Java · PHP · CMS</text>

    <line x1="276" y1="195" x2="370" y2="240" stroke="rgba(56,189,248,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <rect x="330" y="220" width="120" height="44" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="390" y="240" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">Modernisierung</text>
    <text x="390" y="254" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Migration · Cloud</text>

    <line x1="204" y1="195" x2="110" y2="240" stroke="rgba(56,189,248,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <rect x="30" y="220" width="120" height="44" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="90" y="240" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">GIS</text>
    <text x="90" y="254" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">PostGIS · Geo</text>

    <line x1="204" y1="155" x2="110" y2="110" stroke="rgba(245,158,11,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <rect x="30" y="85" width="120" height="44" rx="4" fill="rgba(245,158,11,0.08)" stroke="rgba(245,158,11,0.5)" stroke-width="1.5"/>
    <text x="90" y="105" text-anchor="middle" fill="#f59e0b" font-size="10" font-family="IBM Plex Mono, monospace">KI-gestützt</text>
    <text x="90" y="119" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">AGM · Enterprise API</text>

    <line x1="240" y1="211" x2="240" y2="280" stroke="rgba(56,189,248,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
    <rect x="155" y="285" width="170" height="44" rx="4" fill="rgba(14,165,233,0.08)" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="240" y="305" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">30+ Jahre Praxis</text>
    <text x="240" y="319" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Enterprise · Logistik · GIS</text>
  </svg>
</PageGraphic>
