---
import PageGraphic from '../PageGraphic.astro';
---

<PageGraphic caption="agm · assistant ui">
  <svg viewBox="0 0 480 360" class="w-full" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="AGM Assistant UI — Golden Path von Install bis Verify">
    <defs>
      <pattern id="ag-ui-grid" width="24" height="24" patternUnits="userSpaceOnUse">
        <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(56,189,248,0.1)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="480" height="360" fill="url(#ag-ui-grid)"/>

    <rect x="40" y="40" width="400" height="48" rx="4" fill="rgba(14,165,233,0.1)" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="240" y="62" text-anchor="middle" fill="#38bdf8" font-size="9" font-family="IBM Plex Mono, monospace">AGM ASSISTANT</text>
    <text x="240" y="76" text-anchor="middle" fill="#94a3b8" font-size="8" font-family="IBM Plex Mono, monospace">Build · Evolve · Verify</text>

    <line x1="60" y1="130" x2="420" y2="130" stroke="rgba(56,189,248,0.25)" stroke-width="1.5"/>
    <circle cx="80" cy="130" r="10" fill="#0c1220" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="80" y="134" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">1</text>
    <circle cx="160" cy="130" r="10" fill="#0c1220" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="160" y="134" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">2</text>
    <circle cx="240" cy="130" r="10" fill="#0c1220" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="240" y="134" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">3</text>
    <circle cx="320" cy="130" r="10" fill="#0c1220" stroke="rgba(148,163,184,0.5)" stroke-width="1.5"/>
    <text x="320" y="134" text-anchor="middle" fill="#94a3b8" font-size="8" font-family="IBM Plex Mono, monospace">4</text>
    <circle cx="400" cy="130" r="10" fill="#0c1220" stroke="rgba(245,158,11,0.5)" stroke-width="1.5"/>
    <text x="400" y="134" text-anchor="middle" fill="#f59e0b" font-size="8" font-family="IBM Plex Mono, monospace">5</text>

    <text x="80" y="158" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Install</text>
    <text x="160" y="158" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Adopt</text>
    <text x="240" y="158" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Continue</text>
    <text x="320" y="158" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Evolve</text>
    <text x="400" y="158" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">Verify</text>

    <rect x="60" y="190" width="360" height="120" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.4)" stroke-width="1"/>
    <text x="80" y="220" fill="#e2e8f0" font-size="9" font-family="IBM Plex Mono, monospace">Session mode</text>
    <text x="80" y="240" fill="#64748b" font-size="8" font-family="IBM Plex Mono, monospace">Copy prompt  ·  MCP in IDE</text>
    <rect x="80" y="260" width="140" height="28" rx="4" fill="rgba(14,165,233,0.15)" stroke="#38bdf8" stroke-width="1"/>
    <text x="150" y="278" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">Copy session prompt</text>
    <rect x="240" y="260" width="140" height="28" rx="4" fill="rgba(255,255,255,0.04)" stroke="rgba(148,163,184,0.4)" stroke-width="1"/>
    <text x="310" y="278" text-anchor="middle" fill="#94a3b8" font-size="8" font-family="IBM Plex Mono, monospace">agm_trigger_workflow</text>
  </svg>
</PageGraphic>
