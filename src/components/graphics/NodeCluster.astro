---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['max-h-80 w-full max-w-sm', className]}
  viewBox="0 0 360 320"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Abstrakte Netzwerk-Visualisierung"
>
  <title>Abstrakte Architektur-Grafik</title>
  <line x1="80" y1="160" x2="180" y2="80" stroke="rgba(148,163,184,0.5)" stroke-width="1.5" />
  <line x1="180" y1="80" x2="280" y2="140" stroke="#38bdf8" stroke-width="2" />
  <line x1="180" y1="80" x2="160" y2="220" stroke="rgba(148,163,184,0.5)" stroke-width="1.5" />
  <line x1="160" y1="220" x2="280" y2="140" stroke="rgba(148,163,184,0.5)" stroke-width="1.5" />
  <line x1="80" y1="160" x2="160" y2="220" stroke="rgba(56,189,248,0.3)" stroke-width="1.5" stroke-dasharray="4 4" />
  <line x1="280" y1="140" x2="300" y2="240" stroke="#38bdf8" stroke-width="1.5" />
  <line x1="160" y1="220" x2="60" y2="260" stroke="rgba(148,163,184,0.4)" stroke-width="1" />
  <line x1="180" y1="80" x2="260" y2="40" stroke="rgba(245,158,11,0.4)" stroke-width="1" stroke-dasharray="3 3" />

  <circle cx="80" cy="160" r="14" fill="rgba(255,255,255,0.08)" stroke="rgba(148,163,184,0.6)" stroke-width="1.5" />
  <circle cx="180" cy="80" r="20" fill="#0ea5e9" stroke="#38bdf8" stroke-width="2" />
  <circle cx="280" cy="140" r="16" fill="rgba(255,255,255,0.08)" stroke="#38bdf8" stroke-width="1.5" />
  <circle cx="160" cy="220" r="12" fill="rgba(14,165,233,0.15)" stroke="rgba(56,189,248,0.6)" stroke-width="1.5" />
  <circle cx="300" cy="240" r="10" fill="rgba(255,255,255,0.06)" stroke="rgba(148,163,184,0.5)" stroke-width="1.5" />
  <circle cx="60" cy="260" r="8" fill="rgba(255,255,255,0.06)" stroke="rgba(148,163,184,0.4)" stroke-width="1.5" />
  <circle cx="260" cy="40" r="6" fill="rgba(245,158,11,0.2)" stroke="rgba(245,158,11,0.5)" stroke-width="1" />

  <circle cx="180" cy="80" r="6" fill="#ffffff" opacity="0.9" />

  <rect x="220" y="260" width="100" height="36" rx="6" fill="rgba(255,255,255,0.06)" stroke="rgba(148,163,184,0.4)" stroke-width="1.5" />
  <rect x="230" y="270" width="80" height="8" rx="2" fill="rgba(56,189,248,0.4)" />
  <rect x="230" y="282" width="56" height="6" rx="2" fill="rgba(255,255,255,0.1)" />
</svg>
