---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['h-full w-full', className]}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <pattern id="grid-dots" width="24" height="24" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="1" fill="#8494a7" opacity="0.35" />
    </pattern>
    <pattern id="grid-lines" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#8494a7" stroke-width="0.5" opacity="0.2" />
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="url(#grid-dots)" />
  <rect width="100%" height="100%" fill="url(#grid-lines)" />
</svg>
