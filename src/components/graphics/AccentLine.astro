---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['h-8 w-24', className]}
  viewBox="0 0 96 32"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <line x1="0" y1="16" x2="72" y2="16" stroke="#0c4a6e" stroke-width="2" />
  <polyline points="64,8 80,16 64,24" stroke="#0c4a6e" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" />
</svg>
