---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<svg
  class:list={['h-32 w-32', className]}
  viewBox="0 0 128 128"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <rect x="16" y="72" width="72" height="40" rx="4" fill="#ffffff" stroke="#94a3b8" stroke-width="1.5" />
  <rect x="28" y="84" width="48" height="6" rx="2" fill="#c7dce8" />
  <rect x="28" y="96" width="32" height="4" rx="1" fill="#e4e9ef" />

  <rect x="36" y="44" width="64" height="36" rx="4" fill="#ffffff" stroke="#0c4a6e" stroke-width="1.5" />
  <rect x="48" y="56" width="40" height="5" rx="2" fill="#0c4a6e" opacity="0.25" />
  <rect x="48" y="66" width="28" height="4" rx="1" fill="#c7dce8" />

  <rect x="56" y="20" width="56" height="32" rx="4" fill="#c7dce8" stroke="#0c4a6e" stroke-width="1.5" opacity="0.85" />
  <rect x="68" y="30" width="32" height="4" rx="1" fill="#0c4a6e" opacity="0.4" />
  <rect x="68" y="38" width="24" height="3" rx="1" fill="#ffffff" opacity="0.7" />

  <line x1="52" y1="80" x2="68" y2="56" stroke="#94a3b8" stroke-width="1" stroke-dasharray="3 2" />
  <line x1="84" y1="52" x2="72" y2="72" stroke="#0c4a6e" stroke-width="1" stroke-dasharray="3 2" />
</svg>
