---
interface Props {
  class?: string;
  size?: 'hero' | 'mini' | 'page';
}

const { class: className = '', size = 'hero' } = Astro.props;
const isHero = size === 'hero';
const isPage = size === 'page';
---

<div
  class:list={[
    'blueprint-frame relative',
    isHero ? 'w-full max-w-2xl' : isPage ? 'w-full max-w-sm' : 'w-full max-w-xs',
    isHero && 'blueprint-frame--hero',
    className,
  ]}
>
  <!-- Title block (technical drawing style) -->
  {isHero && (
    <div class="absolute -top-px left-8 z-10 flex items-center gap-3 border border-dashed border-accent/30 bg-ink/90 px-3 py-1 font-mono text-[0.55rem] uppercase tracking-widest text-accent-hover/80 backdrop-blur-sm">
      <span>AGM</span>
      <span class="text-white/20">|</span>
      <span>Rev. 1.0</span>
      <span class="text-white/20">|</span>
      <span>Scale 1:1</span>
    </div>
  )}

  <svg
    viewBox="0 0 480 420"
    class:list={['w-full', isHero && 'blueprint-svg-pulse']}
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Architecture Graph Method: blueprint.md als Zentrum eines verlinkten Dokumentationsgraphen"
  >
    <title>AGM Architecture Graph</title>

    <defs>
      <pattern id="bp-grid" width="24" height="24" patternUnits="userSpaceOnUse">
        <path d="M 24 0 L 0 0 0 24" fill="none" stroke="rgba(56,189,248,0.14)" stroke-width="0.5"/>
      </pattern>
      <pattern id="bp-grid-major" width="96" height="96" patternUnits="userSpaceOnUse">
        <path d="M 96 0 L 0 0 0 96" fill="none" stroke="rgba(56,189,248,0.22)" stroke-width="0.75"/>
      </pattern>
      <marker id="bp-arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
        <path d="M0,0 L0,6 L6,3 z" fill="rgba(56,189,248,0.7)"/>
      </marker>
      <marker id="bp-dim" markerWidth="4" markerHeight="4" refX="2" refY="2" orient="auto">
        <path d="M0,0 L4,4 M4,0 L0,4" stroke="rgba(56,189,248,0.4)" stroke-width="0.5"/>
      </marker>
      <filter id="bp-glow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="5" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <linearGradient id="bp-center-fill" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="rgba(14,165,233,0.22)"/>
        <stop offset="100%" stop-color="rgba(14,165,233,0.08)"/>
      </linearGradient>
    </defs>

    <rect width="480" height="420" fill="url(#bp-grid-major)"/>
    <rect width="480" height="420" fill="url(#bp-grid)"/>

    <!-- Crosshair center reference -->
    <line x1="240" y1="0" x2="240" y2="420" stroke="rgba(56,189,248,0.06)" stroke-width="0.5" stroke-dasharray="4 8"/>
    <line x1="0" y1="195" x2="480" y2="195" stroke="rgba(56,189,248,0.06)" stroke-width="0.5" stroke-dasharray="4 8"/>

    <!-- Corner registration marks -->
    <path d="M16 16 H48 M16 16 V48" stroke="rgba(56,189,248,0.45)" stroke-width="1.5"/>
    <path d="M464 16 H432 M464 16 V48" stroke="rgba(56,189,248,0.45)" stroke-width="1.5"/>
    <path d="M16 404 H48 M16 404 V372" stroke="rgba(56,189,248,0.45)" stroke-width="1.5"/>
    <path d="M464 404 H432 M464 404 V372" stroke="rgba(56,189,248,0.45)" stroke-width="1.5"/>

    <!-- Dimension lines -->
    <line x1="16" y1="430" x2="464" y2="430" stroke="rgba(56,189,248,0.25)" stroke-width="0.75" marker-start="url(#bp-dim)" marker-end="url(#bp-dim)"/>
    <text x="240" y="418" text-anchor="middle" fill="rgba(56,189,248,0.35)" font-size="7" font-family="IBM Plex Mono, monospace">480 u · docs/architecture/</text>

    <!-- Edges (graph links) -->
    <g class="blueprint-edges">
      <line x1="240" y1="195" x2="120" y2="95" stroke="rgba(56,189,248,0.55)" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#bp-arrow)"/>
      <line x1="240" y1="195" x2="360" y2="85" stroke="rgba(56,189,248,0.55)" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#bp-arrow)"/>
      <line x1="240" y1="195" x2="80" y2="210" stroke="rgba(56,189,248,0.45)" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#bp-arrow)"/>
      <line x1="240" y1="195" x2="400" y2="200" stroke="rgba(56,189,248,0.55)" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#bp-arrow)"/>
      <line x1="240" y1="195" x2="160" y2="330" stroke="rgba(56,189,248,0.45)" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#bp-arrow)"/>
      <line x1="240" y1="195" x2="340" y2="320" stroke="rgba(56,189,248,0.55)" stroke-width="1.5" stroke-dasharray="5 3" marker-end="url(#bp-arrow)"/>
      <line x1="240" y1="195" x2="240" y2="355" stroke="rgba(245,158,11,0.55)" stroke-width="1.5" stroke-dasharray="4 4" marker-end="url(#bp-arrow)"/>
      <line x1="160" y1="330" x2="340" y2="320" stroke="rgba(148,163,184,0.3)" stroke-width="1" stroke-dasharray="3 3"/>
    </g>

    <!-- Node: always-on.md -->
    <rect x="60" y="60" width="120" height="44" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(148,163,184,0.55)" stroke-width="1.5"/>
    <text x="120" y="80" text-anchor="middle" fill="#94a3b8" font-size="9" font-family="IBM Plex Mono, monospace">context/</text>
    <text x="120" y="94" text-anchor="middle" fill="#e2e8f0" font-size="10" font-weight="500" font-family="IBM Plex Mono, monospace">always-on.md</text>
    <text x="172" y="72" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">[x]</text>

    <!-- Node: entry-point.md -->
    <rect x="300" y="50" width="130" height="44" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(148,163,184,0.55)" stroke-width="1.5"/>
    <text x="365" y="78" text-anchor="middle" fill="#e2e8f0" font-size="10" font-weight="500" font-family="IBM Plex Mono, monospace">entry-point.md</text>
    <text x="365" y="92" text-anchor="middle" fill="#64748b" font-size="8" font-family="IBM Plex Mono, monospace">navigation</text>
    <text x="418" y="62" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">[x]</text>

    <!-- CENTRAL: blueprint.md -->
    <rect x="155" y="148" width="170" height="82" rx="6" fill="url(#bp-center-fill)" stroke="#38bdf8" stroke-width="2.5" filter="url(#bp-glow)"/>
    <rect x="155" y="148" width="170" height="82" rx="6" fill="none" stroke="rgba(56,189,248,0.3)" stroke-width="1" stroke-dasharray="3 2"/>
    <text x="240" y="174" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace" letter-spacing="0.15em">ORCHESTRATOR</text>
    <text x="240" y="198" text-anchor="middle" fill="#f1f5f9" font-size="16" font-weight="600" font-family="IBM Plex Mono, monospace">blueprint.md</text>
    <text x="240" y="216" text-anchor="middle" fill="#94a3b8" font-size="8" font-family="IBM Plex Mono, monospace">phases · WRK · session log</text>

    <!-- Node: arc42/ -->
    <rect x="20" y="195" width="100" height="44" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(148,163,184,0.55)" stroke-width="1.5"/>
    <text x="70" y="222" text-anchor="middle" fill="#e2e8f0" font-size="10" font-weight="500" font-family="IBM Plex Mono, monospace">arc42/</text>
    <text x="108" y="207" fill="#f59e0b" font-size="7" font-family="IBM Plex Mono, monospace">[~]</text>

    <!-- Node: interfaces/ -->
    <rect x="360" y="185" width="110" height="44" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(148,163,184,0.55)" stroke-width="1.5"/>
    <text x="415" y="212" text-anchor="middle" fill="#e2e8f0" font-size="10" font-weight="500" font-family="IBM Plex Mono, monospace">interfaces/</text>

    <!-- Node: work/WRK-002 -->
    <rect x="90" y="310" width="140" height="48" rx="4" fill="rgba(14,165,233,0.08)" stroke="#38bdf8" stroke-width="1.5"/>
    <text x="160" y="332" text-anchor="middle" fill="#38bdf8" font-size="8" font-family="IBM Plex Mono, monospace">work/</text>
    <text x="160" y="348" text-anchor="middle" fill="#e2e8f0" font-size="9" font-weight="500" font-family="IBM Plex Mono, monospace">WRK-002 security</text>

    <!-- Node: index.md -->
    <rect x="280" y="305" width="120" height="44" rx="4" fill="rgba(255,255,255,0.05)" stroke="rgba(148,163,184,0.55)" stroke-width="1.5"/>
    <text x="340" y="332" text-anchor="middle" fill="#e2e8f0" font-size="10" font-family="IBM Plex Mono, monospace">index.md</text>
    <text x="340" y="344" text-anchor="middle" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">OKF · index.md</text>

    <!-- Node: review -->
    <rect x="195" y="360" width="90" height="36" rx="4" fill="rgba(245,158,11,0.1)" stroke="rgba(245,158,11,0.55)" stroke-width="1.5"/>
    <text x="240" y="382" text-anchor="middle" fill="#f59e0b" font-size="9" font-weight="500" font-family="IBM Plex Mono, monospace">review/</text>

    <!-- Legend -->
    <rect x="28" y="368" width="130" height="36" rx="4" fill="rgba(0,0,0,0.3)" stroke="rgba(148,163,184,0.25)" stroke-width="1"/>
    <text x="40" y="384" fill="#64748b" font-size="7" font-family="IBM Plex Mono, monospace">[x] done  [~] active  [ ] pending</text>
    <text x="40" y="396" fill="#38bdf8" font-size="7" font-family="IBM Plex Mono, monospace">AGM · Architecture Graph</text>
  </svg>

  {isHero && (
    <div class="absolute -bottom-3 left-6 right-6 flex justify-between font-mono text-[0.6rem] text-accent-hover/70">
      <span>docs/architecture/</span>
      <span>deterministic traversal</span>
    </div>
  )}
</div>
