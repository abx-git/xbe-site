---
import { newsSection, getLatestNews } from '../content/news';
import NewsCard from './NewsCard.astro';

interface Props {
  title?: string;
  description?: string;
  limit?: number;
}

const {
  title = newsSection.title,
  description = newsSection.description,
  limit = 2,
} = Astro.props;
const articles = getLatestNews(limit);
---

{
  articles.length > 0 && (
    <section class="blueprint-grid-light relative border-t border-border py-20 sm:py-28">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="section-header mb-10 flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
          <div class="max-w-2xl">
            <div class="section-label !mb-3">
              <span>News</span>
            </div>
            <h2 class="display-md text-text">{title}</h2>
            <p class="mt-3 leading-relaxed text-text-muted">{description}</p>
          </div>
          <a
            href="/news"
            class="hidden shrink-0 font-mono text-xs font-medium text-accent-deep no-underline transition-colors hover:text-accent sm:inline-flex sm:items-center sm:gap-1.5"
          >
            Alle Beiträge
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
        <div class="space-y-6">
          {articles.map((article, index) => (
            <NewsCard {...article} featured={index === 0} />
          ))}
        </div>
        <a
          href="/news"
          class="mt-8 inline-flex font-mono text-xs font-medium text-accent-deep no-underline transition-colors hover:text-accent sm:hidden"
        >
          Alle Beiträge →
        </a>
      </div>
    </section>
  )
}
