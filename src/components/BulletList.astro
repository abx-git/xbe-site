---
interface Props {
  title: string;
  items: readonly string[];
}

const { title, items } = Astro.props;
---

<div class="mt-6">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-text">{title}</h3>
  <ul class="mt-3 space-y-2">
    {
      items.map((item) => (
        <li class="flex gap-3 text-sm leading-relaxed text-text-muted">
          <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
          {item}
        </li>
      ))
    }
  </ul>
</div>
