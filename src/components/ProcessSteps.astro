---
interface Step {
  number: string;
  title: string;
  description: string;
  deliverables?: readonly string[];
}

interface Props {
  steps: readonly Step[];
}

const { steps } = Astro.props;

const stepPaths = [
  'blueprint.md#phase-1',
  'blueprint.md#phase-2',
  'work/WRK-001',
  'arc42/08-crosscutting',
  'work/WRK-00N',
];
---

<div class="relative">
  <div
    class="absolute left-6 top-0 hidden h-full w-px bg-gradient-to-b from-accent via-accent/40 to-transparent md:block"
    aria-hidden="true"
  ></div>
  <div class="space-y-12">
    {
      steps.map((step, index) => (
        <div class="relative flex gap-8">
          <div class="flex shrink-0 flex-col items-center">
            <span class="relative flex h-14 w-14 items-center justify-center rounded-full border-2 border-accent/30 bg-ink font-mono text-sm font-medium text-accent-hover shadow-glow">
              {step.number}
            </span>
          </div>
          <div
            class="process-step-card card card-interactive flex-1 p-7"
            data-path={stepPaths[index] ?? 'blueprint.md'}
          >
            <span class="watermark-num absolute right-4 top-2 opacity-60" aria-hidden="true">
              {step.number}
            </span>
            <p class="eyebrow text-accent-deep">Phase {step.number}</p>
            <h2 class="mt-1 text-lg font-semibold text-text">{step.title}</h2>
            <p class="mt-3 leading-relaxed text-text-muted">{step.description}</p>
            {
              step.deliverables && step.deliverables.length > 0 && (
                <ul class="mt-5 space-y-2 border-t border-border pt-5">
                  {step.deliverables.map((item) => (
                    <li class="flex gap-3 text-sm leading-relaxed text-text-muted">
                      <span class="mt-2 h-1 w-1 shrink-0 rounded-full bg-accent" aria-hidden="true"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              )
            }
          </div>
        </div>
      ))
    }
  </div>
</div>
