---
import { navItems, siteConfig } from '../content/site';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const isHome = currentPath === '/';
const mainNavItems = navItems.filter((item) => item.href !== '/kontakt');
const isContactPage = currentPath === '/kontakt';
---

<header class:list={['sticky top-0 z-50', isHome ? 'header-bar' : 'header-bar--light']}>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <a href="/" class="group flex items-center gap-3">
      <span
        class:list={[
          'flex h-8 w-8 items-center justify-center rounded-lg text-xs font-bold',
          isHome
            ? 'bg-accent/20 text-accent-hover'
            : 'bg-accent-subtle text-accent-deep',
        ]}
        aria-hidden="true"
      >
        X
      </span>
      <span class="flex flex-col leading-tight">
        <span
          class:list={[
            'text-sm font-semibold tracking-wide',
            isHome ? 'text-text-on-dark' : 'text-text',
          ]}
        >
          {siteConfig.name}
        </span>
        <span
          class:list={[
            'eyebrow !text-[0.6rem] !tracking-[0.1em]',
            isHome ? 'text-text-muted-on-dark' : 'text-text-muted',
          ]}
        >
          {siteConfig.tagline}
        </span>
      </span>
    </a>

    <nav class="hidden items-center gap-0.5 md:flex" aria-label="Hauptnavigation">
      {
        mainNavItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-full px-3.5 py-2 text-sm transition-all duration-200',
              currentPath === item.href
                ? isHome
                  ? 'bg-white/12 font-medium text-white'
                  : 'bg-ink font-medium text-text-on-dark'
                : isHome
                  ? 'text-text-muted-on-dark hover:bg-white/8 hover:text-white'
                  : 'text-text-muted hover:bg-bg-subtle hover:text-text',
            ]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <a
      href="/kontakt"
      class:list={[
        'hidden rounded-full px-4 py-2 text-sm font-medium transition-all md:inline-flex',
        isContactPage
          ? isHome
            ? 'bg-white/12 text-white'
            : 'bg-ink text-text-on-dark'
          : isHome
            ? 'bg-accent text-white hover:bg-accent-hover'
            : 'bg-ink text-text-on-dark hover:bg-ink-muted',
      ]}
      aria-current={isContactPage ? 'page' : undefined}
    >
      Kontakt
    </a>

    <button
      id="menu-toggle"
      class:list={[
        'flex h-11 w-11 items-center justify-center rounded-lg border md:hidden',
        isHome
          ? 'border-white/15 text-text-on-dark'
          : 'border-border-strong text-text',
      ]}
      aria-label="Menü öffnen"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path id="menu-icon-open" stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
        <path id="menu-icon-close" class="hidden" stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class:list={[
      'hidden border-t md:hidden',
      isHome ? 'border-white/10 bg-ink' : 'border-border-strong bg-bg-elevated',
    ]}
    aria-label="Mobile Navigation"
  >
    <div class="mx-auto flex max-w-6xl flex-col px-4 py-2 sm:px-6">
      {
        mainNavItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-3 text-sm transition-colors',
              currentPath === item.href
                ? isHome
                  ? 'font-medium text-accent-hover'
                  : 'font-medium text-accent-deep'
                : isHome
                  ? 'text-text-muted-on-dark hover:text-white'
                  : 'text-text-muted hover:text-text',
            ]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/kontakt"
        class:list={[
          'mt-2 rounded-lg px-3 py-3 text-sm font-medium transition-colors',
          isContactPage
            ? isHome
              ? 'text-accent-hover'
              : 'text-accent-deep'
            : isHome
              ? 'text-text-on-dark'
              : 'text-text',
        ]}
        aria-current={isContactPage ? 'page' : undefined}
      >
        Kontakt
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Menü öffnen' : 'Menü schließen');
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Menü öffnen');
    });
  });
</script>
