---
import { navItems, siteConfig } from '../content/site';
---

<footer class="border-t border-border bg-ink text-text-on-dark">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="flex flex-col gap-10 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <div class="flex items-center gap-3">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent/20 text-xs font-bold text-accent-hover" aria-hidden="true">X</span>
          <div>
            <p class="text-sm font-semibold">{siteConfig.name}</p>
            <p class="mt-0.5 text-xs text-text-muted-on-dark">{siteConfig.ownerName}</p>
            <p class="eyebrow mt-1 !text-[0.6rem] text-text-muted-on-dark">{siteConfig.tagline}</p>
          </div>
        </div>
        <p class="mt-5 max-w-xs text-sm leading-relaxed text-text-muted-on-dark">
          Architekturberatung und KI-gestützte Softwareentwicklung — evidenzbasiert, validiert, DSGVO-konform.
        </p>
      </div>
      <nav class="flex flex-wrap gap-x-8 gap-y-3 text-sm" aria-label="Footer Navigation">
        {
          navItems.slice(1).map((item) => (
            <a href={item.href} class="text-text-muted-on-dark transition-colors hover:text-accent-hover">
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
    <div class="mt-12 flex flex-col gap-3 border-t border-white/10 pt-8 text-xs text-text-muted-on-dark sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {new Date().getFullYear()} {siteConfig.ownerName} · {siteConfig.name}</p>
      <div class="flex gap-6">
        <a href="/impressum" class="transition-colors hover:text-accent-hover">Impressum</a>
        <a href="/datenschutz" class="transition-colors hover:text-accent-hover">Datenschutz</a>
        <a
          href={siteConfig.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-accent-hover"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</footer>
