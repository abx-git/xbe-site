---
import EmailAddress from './EmailAddress.astro';

interface Section {
  heading: string;
  content: readonly string[];
}

interface Props {
  sections: readonly Section[];
}

const { sections } = Astro.props;
---

<div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16">
  <div class="max-w-2xl space-y-10">
    {
      sections.map((section) => (
        <section>
          <h2 class="text-base font-semibold text-text">{section.heading}</h2>
          <div class="mt-3 space-y-1 text-sm leading-relaxed text-text-muted">
            {
              section.content.map((line) =>
                line === '__EMAIL__' ? (
                  <p>
                    E-Mail: <EmailAddress />
                  </p>
                ) : (
                  <p>{line}</p>
                ),
              )
            }
          </div>
        </section>
      ))
    }
  </div>
</div>
